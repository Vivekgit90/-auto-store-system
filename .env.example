# WordPress/WooCommerce Configuration
WP_API_URL=https://your-wordpress-site.com
WP_USER=admin
WP_APP_PASSWORD=your_app_password_here

# Free AI APIs (Optional - for logo/content generation)
OPENAI_API_KEY=
STABILITY_API_KEY=

# Payment Gateways (Sign up for free accounts)
# Stripe: https://stripe.com (Free account)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# PayPal: https://developer.paypal.com (Free sandbox)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret

# Razorpay: https://razorpay.com (Free for India)
RAZORPAY_KEY=
RAZORPAY_SECRET=

# Supplier APIs (Optional)
ALIEXPRESS_API_KEY=
CJDROPSHIPPING_API_KEY=

# Analytics (Free)
# Google Analytics: https://analytics.google.com
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel: https://business.facebook.com
META_PIXEL_ID=

# Email Configuration (Free Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password

# Image Compression (Free tier: 500/month)
# TinyPNG: https://tinypng.com/developers
TINIFY_API_KEY=

# Database
DB_PATH=./store_automation.db

# Webhook Configuration
WEBHOOK_SECRET=your_webhook_secret_key
WEBHOOK_PORT=8080
